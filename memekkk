function gStone()
    local it = PlayerData:GetExpect({ "Inventory", "Items" })
    if not it then return 0 end
    
    local targetId = STONE_IDS[_G.SelectedStoneType]
    local total = 0
    
    for _, v in ipairs(it) do
        if v.Id == targetId then
            total = total + (v.Quantity or 1)
        end
    end
    return total
end

