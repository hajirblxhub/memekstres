local AUTO_3_TOTEM_ACTIVE = false
local AUTO_3_TOTEM_THREAD = nil

local TOTEM_MIX_CONFIG = {
    { name = "Shiny Totem",   id = 3 },
    { name = "Luck Totem",    id = 1 },
    { name = "Mutation Totem", id = 2 }
}

local REF_CENTER = Vector3.new(93.932, 9.532, 2684.134)
local REF_SPOTS = {
    Vector3.new(45.0468979,  13.5, 2730.19067),   -- Shiny
    Vector3.new(145.644608,  13.5, 2721.90747),   -- Luck
    Vector3.new(84.6406631,  14.2, 2636.05786),   -- Mutation
}

local function GetMixTotemUUID(targetId)
    local uuid = nil
    pcall(function()
        local inv = PlayerData:GetExpect("Inventory")
        if inv and inv.Totems then
            for _, item in ipairs(inv.Totems) do
                if item.Id == targetId then
                    uuid = item.UUID
                    return
                end
            end
        end
    end)
    return uuid
end

local function TweenTo(targetCFrame, duration)
    local hrp = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
    if not hrp then return false end
    
    local tweenService = game:GetService("TweenService")
    local tweenInfo = TweenInfo.new(duration, Enum.EasingStyle.Linear, Enum.EasingDirection.Out)
    
    hrp.Anchored = true
    local tween = tweenService:Create(hrp, tweenInfo, {CFrame = targetCFrame})
    tween:Play()
    tween.Completed:Wait()
    
    task.wait(0.15)
    return true
end

local function RunMixTotemLoop()
    if AUTO_3_TOTEM_THREAD then task.cancel(AUTO_3_TOTEM_THREAD) end
    
    AUTO_3_TOTEM_THREAD = task.spawn(function()
        while AUTO_3_TOTEM_ACTIVE do
            local hrp = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
            if not hrp then 
                task.wait(6) 
                continue 
            end

            local startCFrame = hrp.CFrame
            WindUI:Notify({
                Title = "Mix Totem",
                Content = "Memulai ritual 3 totem mix...",
                Duration = 3.5
            })

            local platforms = {}

            for i, totem in ipairs(TOTEM_MIX_CONFIG) do
                if not AUTO_3_TOTEM_ACTIVE then break end

                local offset = REF_SPOTS[i] - REF_CENTER
                local targetPos = startCFrame.Position + offset
                local targetCFrame = CFrame.new(targetPos) * CFrame.Angles(0, math.rad(180), 0)

                if not TweenTo(targetCFrame, 1.8) then continue end

                local p = Instance.new("Part")
                p.Name = "TempTotemPlatform"
                p.Size = Vector3.new(10, 1, 10)
                p.CFrame = targetCFrame * CFrame.new(0, -3.2, 0)
                p.Anchored = true
                p.CanCollide = true
                p.Transparency = 0.7
                p.BrickColor = BrickColor.new("Really red")
                p.Material = Enum.Material.Neon
                p.Parent = workspace
                table.insert(platforms, p)

                hrp.Anchored = false
                task.wait(0.9)

                local uuid = GetMixTotemUUID(totem.id)
                if uuid and Events.SpawnTotem then
                    Events.SpawnTotem:FireServer(uuid)
                    
                    task.spawn(function()
                        task.wait(0.4)
                        for _ = 1, 6 do
                            pcall(function() 
                                if Events.equip then Events.equip:FireServer(1) end
                            end)
                            task.wait(0.25)
                        end
                    end)

                    WindUI:Notify({
                        Title = totem.name,
                        Content = "Spawn berhasil!",
                        Duration = 2.2
                    })
                else
                    WindUI:Notify({
                        Title = "Gagal",
                        Content = totem.name .. " tidak ditemukan di inv",
                        Duration = 3
                    })
                end

                task.wait(3.5)
            end

            -- Bersihkan platform
            for _, p in ipairs(platforms) do
                pcall(function() p:Destroy() end)
            end

            if AUTO_3_TOTEM_ACTIVE then
                TweenTo(startCFrame, 1.8)
                hrp.Anchored = false
                
                WindUI:Notify({
                    Title = "Ritual Selesai",
                    Content = "Cooldown 1 jam dimulai...",
                    Duration = 5
                })

                for remaining = 3600, 1, -60 do
                    if not AUTO_3_TOTEM_ACTIVE then break end
                    task.wait(60)
                end
            end
        end
    end)
end

