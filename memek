-- Fitur No Animation: Stop semua animasi game (rod throw, catch cutscene, idle, dll) untuk performa lebih ringan & stealth

local stopAnimConnections = {}

local function setGameAnimationsEnabled(enabled)
    local character = LocalPlayer.Character
    if not character then return end
    
    local humanoid = character:FindFirstChildOfClass("Humanoid")
    if not humanoid then return end
    
    local animator = humanoid:FindFirstChildOfClass("Animator")
    if not animator then return end
    
    -- Bersihkan koneksi lama
    for _, conn in ipairs(stopAnimConnections) do
        conn:Disconnect()
    end
    stopAnimConnections = {}
    
    if enabled then
        -- Stop semua animasi yang sedang play saat ini
        for _, track in ipairs(animator:GetPlayingAnimationTracks()) do
            track:Stop(0)
        end
        
        -- Hook setiap animasi baru yang diputar → langsung stop
        local playConn = animator.AnimationPlayed:Connect(function(track)
            task.defer(function()
                track:Stop(0)  -- Stop instan tanpa fade
            end)
        end)
        
        table.insert(stopAnimConnections, playConn)
        
        -- Optional: stop animasi humanoid state (run, jump, dll) kalau mau lebih agresif
        -- humanoid:ChangeState(Enum.HumanoidStateType.None)  -- uncomment kalau mau mati total
        
        WindUI:Notify({
            Title = "No Animation",
            Content = "Semua animasi game dimatikan (lebih ringan & stealth)",
            Duration = 4,
            Icon = "pause-circle"
        })
    else
        -- Re-enable: hapus hook saja (animasi game bakal balik normal)
        for _, conn in ipairs(stopAnimConnections) do
            conn:Disconnect()
        end
        stopAnimConnections = {}
        
        WindUI:Notify({
            Title = "Animation Back",
            Content = "Animasi game kembali normal.",
            Duration = 4,
            Icon = "play-circle"
        })
    end
end

