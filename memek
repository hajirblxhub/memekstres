                    elseif txt:match("%d+") or txt:lower():find("lvl") or txt:lower():find("level") then
                        if #txt < 15 then
                            lbl.Text = customLevel
                        end
                    end
                end
            end
        end
    end)
    table.insert(hideNameConnections, conn)
