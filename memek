-- Hitung ikan yang bisa dijual (respect favorit)
local function getSellableFishCount()
    local count = 0
    pcall(function()
        local inv = PlayerData:GetExpect("Inventory")  -- atau DataService:GetExpect("Inventory")
        if inv and inv.Fish then
            for _, fish in pairs(inv.Fish) do
                local favorited = fish.Favorited or fish.IsFavorited or false
                if Config.ForceSellAll or not favorited then
                    count = count + 1
                end
            end
        end
    end)
    return count
end

-- Logic loop auto sell
local function autoSellLogic()
    while Config.AutoSell do
        task.wait(1)
        
        local currentSellable = getSellableFishCount()
        
        if currentSellable <= 0 then
            task.wait(5)
            continue
        end
        
        if Config.SellMode == "Minute" then
            local waitTime = (Config.SellValue * 60) - 1
            if waitTime > 0 then task.wait(waitTime) end
            
            if Config.AutoSell and currentSellable > 0 then
                local before = currentSellable
                sellAll()
                task.wait(3.5)
                local sold = before - getSellableFishCount()
                if sold > 0 then
                    WindUI:Notify({
                        Title = "Auto Sell",
                        Content = "💸 Terjual " .. sold .. " ikan (" .. (Config.ForceSellAll and "All" or "Non-Fav") .. ")",
                        Duration = 5
                    })
                end
            end
        elseif Config.SellMode == "Count" then
            if currentSellable >= Config.SellValue then
                local before = currentSellable
                sellAll()
                task.wait(3.5)
                local sold = before - getSellableFishCount()
                if sold > 0 then
                    WindUI:Notify({
                        Title = "Auto Sell",
                        Content = "💸 Tas penuh! Terjual " .. sold .. " ikan (" .. (Config.ForceSellAll and "All" or "Non-Fav") .. ")",
                        Duration = 5
                    })
                end
            end
            task.wait(4)
        end
    end
end

-- Fungsi update task
local function updateAutoSellTask()
    if Config.AutoSell then
        if Tasks.autoSellTask then task.cancel(Tasks.autoSellTask) end
        Tasks.autoSellTask = task.spawn(autoSellLogic)
    else
        if Tasks.autoSellTask then task.cancel(Tasks.autoSellTask) end
        Tasks.autoSellTask = nil
    end
end

