}

-- Koordinat Spot (Relatif terhadap start)
local REF_CENTER = Vector3.new(93.932, 9.532, 2684.134)
local REF_SPOTS = {
    Vector3.new(45.0468979, 13.5, 2730.19067),   -- Spot Shiny
    Vector3.new(145.644608, 13.5, 2721.90747),  -- Spot Luck
    Vector3.new(84.6406631, 14.2, 2636.05786),  -- Spot Mutation
