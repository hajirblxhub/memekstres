local AUTO_3_TOTEM_ACTIVE = false
local AUTO_3_TOTEM_THREAD = nil

-- Urutan dan ID Totem sesuai data lo
local TOTEM_MIX_CONFIG = {
    { name = "Shiny Totem", id = 3 },
    { name = "Luck Totem", id = 1 },
