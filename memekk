                Content = "Diaktifkan - setiap 30 menit",
                Duration = 3
            })
        else
            if caveCrystalTask then
                task.cancel(caveCrystalTask)
                caveCrystalTask = nil
            end
            WindUI:Notify({
                Title = "Auto Consume",
                Content = "Dimatikan",
                Duration = 2.5
            })
        end
    end
})

